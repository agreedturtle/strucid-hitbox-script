-- AdvanceTech Strucid | Headshot Hitbox + Fly

local flySettings = {flyspeed = 50}
local c, h, bv, bav, cam, flying = nil, nil, nil, nil, nil, false
local p = game.Players.LocalPlayer
local buttons = {W=false, S=false, A=false, D=false, Moving=false}

-- Fly Script
local startFly = function()
    if not p.Character or flying then return end
    c = p.Character
    h = c:FindFirstChild("Humanoid")
    if not h then return end
    h.PlatformStand = true
    cam = workspace.CurrentCamera
    bv = Instance.new("BodyVelocity", c.Head)
    bav = Instance.new("BodyAngularVelocity", c.Head)
    bv.MaxForce = Vector3.new(10000,10000,10000)
    bav.MaxTorque = Vector3.new(10000,10000,10000)
    flying = true
end

local endFly = function()
    if h then h.PlatformStand = false end
    if bv then bv:Destroy() end
    if bav then bav:Destroy() end
    flying = false
end

game:GetService("UserInputService").InputBegan:Connect(function(input,GPE)
    if GPE then return end
    if buttons[input.KeyCode.Name] ~= nil then
        buttons[input.KeyCode.Name] = true
        buttons.Moving = true
    end
end)

game:GetService("UserInputService").InputEnded:Connect(function(input,GPE)
    if GPE then return end
    if buttons[input.KeyCode.Name] ~= nil then
        buttons[input.KeyCode.Name] = false
        local moving = false
        for _,v in pairs(buttons) do if v == true then moving = true end end
        buttons.Moving = moving
    end
end)

game:GetService("RunService").Heartbeat:Connect(function(step)
    if flying and c and c.PrimaryPart then
        local cf = cam.CFrame
        c:SetPrimaryPartCFrame(CFrame.new(c.PrimaryPart.Position) * CFrame.Angles(cf:ToEulerAnglesXYZ()))
        if buttons.Moving then
            local t = Vector3.new()
            if buttons.W then t += cf.LookVector end
            if buttons.S then t -= cf.LookVector end
            if buttons.A then t -= cf.RightVector end
            if buttons.D then t += cf.RightVector end
            c:TranslateBy(t * flySettings.flyspeed * step)
        end
    end
end)

-- UI + Features
local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/Vape.txt"))()
local win = lib:Window("AdvanceTech | Strucid", Color3.fromRGB(44, 120, 224), Enum.KeyCode.P)

local tab = win:Tab("Main")

-- Headshot Hitbox
local headHitboxEnabled = false
local headSize = 12
local headTrans = 0.7
local originals = {}

local function updateHeads()
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= p and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                if not originals[plr] then originals[plr] = head.Size end
                if headHitboxEnabled then
                    head.Size = Vector3.new(headSize, headSize, headSize)
                    head.Transparency = headTrans
                    head.CanCollide = false
                else
                    head.Size = originals[plr] or Vector3.new(1.2,1.2,1.2)
                    head.Transparency = 0
                    head.CanCollide = true
                end
            end
        end
    end
end

tab:Label("> Headshot Hitbox")
tab:Toggle("Enable Head Hitbox", false, function(s)
    headHitboxEnabled = s
    if s then
        game:GetService("RunService").Stepped:Connect(updateHeads)
    else
        updateHeads()
    end
end)

tab:Slider("Head Size", 1, 30, 12, function(v)
    headSize = v
    updateHeads()
end)

tab:Slider("Transparency", 0, 1, 0.7, function(v)
    headTrans = v
    updateHeads()
end)

print("✅ Script Loaded | Press P to open menu")
