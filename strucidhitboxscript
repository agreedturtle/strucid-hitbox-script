-- AdvanceTech | Strucid | Revamped Headshot Hitbox
-- Fixed | No Collision | Clean UI

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInput = game:GetService("UserInputService")

-- ==================== FLY ====================
local flySettings = {flyspeed = 60}
local flying = false
local flyBodyVelocity, flyBodyAngular, flyCharacter, flyHumanoid, flyCam

local function startFly()
    if flying then return end
    flyCharacter = Player.Character
    if not flyCharacter then return end
    flyHumanoid = flyCharacter:FindFirstChild("Humanoid")
    if not flyHumanoid then return end
    
    flyHumanoid.PlatformStand = true
    flyCam = workspace.CurrentCamera
    
    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyAngular = Instance.new("BodyAngularVelocity")
    
    flyBodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    flyBodyAngular.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    
    flyBodyVelocity.Parent = flyCharacter.Head
    flyBodyAngular.Parent = flyCharacter.Head
    flying = true
end

local function endFly()
    if flyHumanoid then flyHumanoid.PlatformStand = false end
    if flyBodyVelocity then flyBodyVelocity:Destroy() end
    if flyBodyAngular then flyBodyAngular:Destroy() end
    flying = false
end

-- Fly Controls
local move = {W=false, S=false, A=false, D=false, Moving=false}

UserInput.InputBegan:Connect(function(i, gp)
    if gp then return end
    if move[i.KeyCode.Name] ~= nil then
        move[i.KeyCode.Name] = true
        move.Moving = true
    end
end)

UserInput.InputEnded:Connect(function(i, gp)
    if gp then return end
    if move[i.KeyCode.Name] ~= nil then
        move[i.KeyCode.Name] = false
        local m = false
        for _,v in pairs(move) do if v then m = true end end
        move.Moving = m
    end
end)

RunService.Heartbeat:Connect(function(dt)
    if flying and flyCharacter and flyCharacter.PrimaryPart then
        local cf = flyCam.CFrame
        flyCharacter:SetPrimaryPartCFrame(CFrame.new(flyCharacter.PrimaryPart.Position) * CFrame.Angles(cf:ToEulerAnglesXYZ()))
        
        if move.Moving then
            local dir = Vector3.new()
            if move.W then dir += cf.LookVector end
            if move.S then dir -= cf.LookVector end
            if move.A then dir -= cf.RightVector end
            if move.D then dir += cf.RightVector end
            flyCharacter:TranslateBy(dir * flySettings.flyspeed * dt)
        end
    end
end)

-- ==================== HEAD HITBOX ====================
local headEnabled = false
local headSize = 14
local headTrans = 0.6
local originalSizes = {}

local headConnection

local function updateHeadHitboxes()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                if not originalSizes[plr] then
                    originalSizes[plr] = head.Size
                end
                
                if headEnabled then
                    head.Size = Vector3.new(headSize, headSize, headSize)
                    head.Transparency = headTrans
                    head.CanCollide = false          -- NO COLLISION
                    head.Massless = true
                else
                    head.Size = originalSizes[plr] or Vector3.new(1.2, 1.2, 1.2)
                    head.Transparency = 0
                    head.CanCollide = true
                    head.Massless = false
                end
            end
        end
    end
end

-- ==================== UI ====================
local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/Vape.txt"))()
local win = lib:Window("AdvanceTech | Strucid", Color3.fromRGB(255, 170, 0), Enum.KeyCode.P)

local main = win:Tab("Main")

main:Label("🎯 Headshot Hitbox")
main:Toggle("Enable Head Hitbox", false, function(state)
    headEnabled = state
    if state then
        if headConnection then headConnection:Disconnect() end
        headConnection = RunService.Stepped:Connect(updateHeadHitboxes)
    else
        if headConnection then 
            headConnection:Disconnect() 
            headConnection = nil 
        end
        updateHeadHitboxes()
    end
end)

main:Slider("Head Size", 1, 35, 14, function(v)
    headSize = v
    if headEnabled then updateHeadHitboxes() end
end)

main:Slider("Transparency", 0, 1, 0.6, function(v)
    headTrans = v
    if headEnabled then updateHeadHitboxes() end
end)

main:Label("🕹️ Fly")
main:Toggle("Enable Fly", false, function(state)
    if state then startFly() else endFly() end
end)

main:Slider("Fly Speed", 10, 200, 60, function(v)
    flySettings.flyspeed = v
end)

main:Label("🔫 Silent Aim (Basic)")
main:Toggle("Silent Aim (Head)", false, function(state)
    -- Simple version - you can expand later
    print("Silent Aim:", state and "ON" or "OFF")
end)

