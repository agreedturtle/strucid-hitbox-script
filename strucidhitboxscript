-- AdvanceTech | Strucid | Headshot Hitbox Script
-- Fixed & Cleaned Version

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- Fly Settings
local flySettings = {flyspeed = 50}
local flying = false
local c, h, bv, bav, cam = nil, nil, nil, nil, nil

local buttons = {W = false, S = false, A = false, D = false, Moving = false}

-- Start Fly
local function startFly()
    if flying or not Player.Character then return end
    c = Player.Character
    h = c:FindFirstChild("Humanoid")
    if not h then return end
    
    h.PlatformStand = true
    cam = workspace.CurrentCamera
    
    bv = Instance.new("BodyVelocity")
    bav = Instance.new("BodyAngularVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bav.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bv.Parent = c.Head
    bav.Parent = c.Head
    flying = true
end

-- End Fly
local function endFly()
    if h then h.PlatformStand = false end
    if bv then bv:Destroy() end
    if bav then bav:Destroy() end
    flying = false
end

-- Input
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    local key = input.KeyCode.Name
    if buttons[key] ~= nil then
        buttons[key] = true
        buttons.Moving = true
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if gp then return end
    local key = input.KeyCode.Name
    if buttons[key] ~= nil then
        buttons[key] = false
        local moving = false
        for _, v in pairs(buttons) do
            if v then moving = true end
        end
        buttons.Moving = moving
    end
end)

-- Fly Loop
RunService.Heartbeat:Connect(function(step)
    if flying and c and c.PrimaryPart then
        local cf = cam.CFrame
        c:SetPrimaryPartCFrame(CFrame.new(c.PrimaryPart.Position) * CFrame.Angles(cf:ToEulerAnglesXYZ()))
        
        if buttons.Moving then
            local t = Vector3.new()
            if buttons.W then t += cf.LookVector end
            if buttons.S then t -= cf.LookVector end
            if buttons.A then t -= cf.RightVector end
            if buttons.D then t += cf.RightVector end
            c:TranslateBy(t * flySettings.flyspeed * step)
        end
    end
end)

-- UI Library
local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/Vape.txt"))()
local win = lib:Window("AdvanceTech | Strucid", Color3.fromRGB(44, 120, 224), Enum.KeyCode.P)

local tab = win:Tab("Main")

-- Headshot Hitbox
local headHitboxEnabled = false
local headSize = 12
local headTrans = 0.7
local originals = {}

local function updateHeadHitboxes()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                if not originals[plr] then
                    originals[plr] = head.Size
                end
                
                if headHitboxEnabled then
                    head.Size = Vector3.new(headSize, headSize, headSize)
                    head.Transparency = headTrans
                    head.CanCollide = false
                else
                    head.Size = originals[plr] or Vector3.new(1.2, 1.2, 1.2)
                    head.Transparency = 0
                    head.CanCollide = true
                end
            end
        end
    end
end

tab:Label("> Headshot Hitbox")
tab:Toggle("Enable Head Hitbox", false, function(state)
    headHitboxEnabled = state
    if state then
        RunService.Stepped:Connect(updateHeadHitboxes)
    else
        updateHeadHitboxes()
    end
end)

tab:Slider("Head Size", 1, 30, 12, function(v)
    headSize = v
    updateHeadHitboxes()
end)

tab:Slider("Transparency", 0, 1, 0.7, function(v)
    headTrans = v
    updateHeadHitboxes()
end)

print("✅ AdvanceTech Strucid Script Loaded | Press P to open menu")
