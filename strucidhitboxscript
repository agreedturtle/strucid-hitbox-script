-- AdvanceTech | Strucid | Aggressive Gun Mods + Head Hitbox + Fly

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInput = game:GetService("UserInputService")

-- ==================== FLY ====================
local flySettings = {flyspeed = 60}
local flying = false
local flyBV, flyBAV, flyChar, flyHum, flyCam

local function startFly()
    if flying or not Player.Character then return end
    flyChar = Player.Character
    flyHum = flyChar:FindFirstChild("Humanoid")
    if not flyHum then return end
    flyHum.PlatformStand = true
    flyCam = workspace.CurrentCamera
    flyBV = Instance.new("BodyVelocity", flyChar.Head)
    flyBAV = Instance.new("BodyAngularVelocity", flyChar.Head)
    flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
    flyBAV.MaxTorque = Vector3.new(1e5,1e5,1e5)
    flying = true
end

local function endFly()
    if flyHum then flyHum.PlatformStand = false end
    if flyBV then flyBV:Destroy() end
    if flyBAV then flyBAV:Destroy() end
    flying = false
end

local move = {W=false,S=false,A=false,D=false,Moving=false}

UserInput.InputBegan:Connect(function(i,gp)
    if gp then return end
    local k = i.KeyCode.Name
    if move[k] ~= nil then move[k] = true; move.Moving = true end
end)

UserInput.InputEnded:Connect(function(i,gp)
    if gp then return end
    local k = i.KeyCode.Name
    if move[k] ~= nil then 
        move[k] = false
        local m = false
        for _,v in pairs(move) do if v then m = true end end
        move.Moving = m
    end
end)

RunService.Heartbeat:Connect(function(dt)
    if flying and flyChar and flyChar.PrimaryPart then
        local cf = flyCam.CFrame
        flyChar:SetPrimaryPartCFrame(CFrame.new(flyChar.PrimaryPart.Position) * CFrame.Angles(cf:ToEulerAnglesXYZ()))
        if move.Moving then
            local dir = Vector3.new()
            if move.W then dir += cf.LookVector end
            if move.S then dir -= cf.LookVector end
            if move.A then dir -= cf.RightVector end
            if move.D then dir += cf.RightVector end
            flyChar:TranslateBy(dir * flySettings.flyspeed * dt)
        end
    end
end)

-- ==================== HEAD HITBOX ====================
local headEnabled = false
local headSize = 14
local headTrans = 0.6
local originalSizes = {}
local headConn

local function updateHeads()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                if not originalSizes[plr] then originalSizes[plr] = head.Size end
                if headEnabled then
                    head.Size = Vector3.new(headSize, headSize, headSize)
                    head.Transparency = headTrans
                    head.CanCollide = false
                    head.Massless = true
                else
                    head.Size = originalSizes[plr] or Vector3.new(1.2,1.2,1.2)
                    head.Transparency = 0
                    head.CanCollide = true
                end
            end
        end
    end
end

-- ==================== AGGRESSIVE GUN MODS ====================
local rapidFire = false
local noReload = false
local moreDamage = false   -- Damage multiplier (may not work)

local function applyGunMods()
    pcall(function()
        local mainGui = Player:FindFirstChild("PlayerGui") and Player.PlayerGui:FindFirstChild("MainGui")
        if not mainGui then return end
        
        local gunModule = require(mainGui.NewLocal.Tools.Tool.Gun)
        if not gunModule then return end

        -- Rapid Fire
        if rapidFire then
            gunModule.FireRate = 0.05
            gunModule.Cooldown = 0.05
            if gunModule.ShotDelay then gunModule.ShotDelay = 0.05 end
            if gunModule.BurstRate then gunModule.BurstRate = 0.05 end
        end

        -- No Reload + Infinite Ammo
        if noReload then
            gunModule.ReloadTime = 0.1
            gunModule.Ammo = 999
            gunModule.MaxAmmo = 999
            gunModule.CurrentAmmo = 999
            if gunModule.ClipSize then gunModule.ClipSize = 999 end
            if gunModule.AmmoInClip then gunModule.AmmoInClip = 999 end
        end

        -- More Damage (might not replicate to server)
        if moreDamage then
            if gunModule.Damage then gunModule.Damage = gunModule.Damage * 2.5 end
            if gunModule.HeadshotMultiplier then gunModule.HeadshotMultiplier = 5 end
        end
    end)
end

-- ==================== NO FALL DAMAGE ====================
local function noFall()
    local hum = Player.Character and Player.Character:FindFirstChild("Humanoid")
    if hum then
        pcall(function()
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end)
    end
end

-- ==================== GUI ====================
local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/Vape.txt"))()
local win = lib:Window("AdvanceTech | Strucid", Color3.fromRGB(255, 140, 0), Enum.KeyCode.P)

local tab = win:Tab("Main")

tab:Label("🎯 Head Hitbox")
tab:Toggle("Enable Head Hitbox", false, function(s)
    headEnabled = s
    if s then
        if headConn then headConn:Disconnect() end
        headConn = RunService.Stepped:Connect(updateHeads)
    else
        if headConn then headConn:Disconnect() end
        updateHeads()
    end
end)

tab:Slider("Head Size", 1, 35, 14, function(v) headSize = v; if headEnabled then updateHeads() end end)
tab:Slider("Head Transparency", 0, 1, 0.6, function(v) headTrans = v; if headEnabled then updateHeads() end end)

tab:Label("🕹️ Movement")
tab:Toggle("Fly", false, function(s) if s then startFly() else endFly() end end)
tab:Slider("Fly Speed", 10, 200, 60, function(v) flySettings.flyspeed = v end)

tab:Label("⚡ Combat")
tab:Toggle("Rapid Fire", false, function(s) rapidFire = s end)
tab:Toggle("No Reload", false, function(s) noReload = s end)
tab:Toggle("More Damage (x2.5)", false, function(s) moreDamage = s end)
tab:Toggle("No Fall Damage", true, function(s)
    if s then RunService.Heartbeat:Connect(noFall) end
end)

-- Gun Mods Loop
RunService.Heartbeat:Connect(function()
    if rapidFire or noReload or moreDamage then
        applyGunMods()
    end
end)

print("✅ AdvanceTech Strucid Loaded | Press P to open menu")
