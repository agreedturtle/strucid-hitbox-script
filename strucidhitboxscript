-- AdvanceTech | Strucid | Improved Rapid Fire + No Reload + No Fall

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInput = game:GetService("UserInputService")

-- ==================== FLY ====================
local flySettings = {flyspeed = 60}
local flying = false
local flyBV, flyBAV, flyChar, flyHum, flyCam

local function startFly()
    if flying or not Player.Character then return end
    flyChar = Player.Character
    flyHum = flyChar:FindFirstChild("Humanoid")
    if not flyHum then return end
    
    flyHum.PlatformStand = true
    flyCam = workspace.CurrentCamera
    
    flyBV = Instance.new("BodyVelocity")
    flyBAV = Instance.new("BodyAngularVelocity")
    flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
    flyBAV.MaxTorque = Vector3.new(1e5,1e5,1e5)
    flyBV.Parent = flyChar.Head
    flyBAV.Parent = flyChar.Head
    flying = true
end

local function endFly()
    if flyHum then flyHum.PlatformStand = false end
    if flyBV then flyBV:Destroy() end
    if flyBAV then flyBAV:Destroy() end
    flying = false
end

local move = {W=false,S=false,A=false,D=false,Moving=false}

UserInput.InputBegan:Connect(function(i,gp) 
    if gp then return end
    local k = i.KeyCode.Name
    if move[k] ~= nil then move[k] = true; move.Moving = true end
end)

UserInput.InputEnded:Connect(function(i,gp)
    if gp then return end
    local k = i.KeyCode.Name
    if move[k] ~= nil then 
        move[k] = false 
        local m = false
        for _,v in pairs(move) do if v then m = true end end
        move.Moving = m
    end
end)

RunService.Heartbeat:Connect(function(dt)
    if flying and flyChar and flyChar.PrimaryPart then
        local cf = flyCam.CFrame
        flyChar:SetPrimaryPartCFrame(CFrame.new(flyChar.PrimaryPart.Position) * CFrame.Angles(cf:ToEulerAnglesXYZ()))
        if move.Moving then
            local dir = Vector3.new()
            if move.W then dir += cf.LookVector end
            if move.S then dir -= cf.LookVector end
            if move.A then dir -= cf.RightVector end
            if move.D then dir += cf.RightVector end
            flyChar:TranslateBy(dir * flySettings.flyspeed * dt)
        end
    end
end)

-- ==================== HEAD HITBOX ====================
local headEnabled = false
local headSize = 14
local headTrans = 0.6
local originalSizes = {}
local headConn

local function updateHeads()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                if not originalSizes[plr] then originalSizes[plr] = head.Size end
                if headEnabled then
                    head.Size = Vector3.new(headSize, headSize, headSize)
                    head.Transparency = headTrans
                    head.CanCollide = false
                    head.Massless = true
                else
                    head.Size = originalSizes[plr] or Vector3.new(1.2,1.2,1.2)
                    head.Transparency = 0
                    head.CanCollide = true
                    head.Massless = false
                end
            end
        end
    end
end

-- ==================== GUN MODS (Rapid Fire + No Reload) ====================
local rapidFireEnabled = false
local noReloadEnabled = false

local function applyGunMods()
    pcall(function()
        local gui = Player:WaitForChild("PlayerGui"):FindFirstChild("MainGui")
        if not gui then return end
        
        local gunModule = require(gui.NewLocal.Tools.Tool.Gun)
        if not gunModule then return end

        if rapidFireEnabled then
            gunModule.FireRate = 0.07          -- Fast but stable
            if gunModule.Cooldown then gunModule.Cooldown = 0.07 end
        end

        if noReloadEnabled then
            gunModule.ReloadTime = 0.1
            if gunModule.Ammo then gunModule.Ammo = 999 end
            if gunModule.MaxAmmo then gunModule.MaxAmmo = 999 end
        end
    end)
end

-- ==================== NO FALL DAMAGE ====================
local function noFallDamage()
    local hum = Player.Character and Player.Character:FindFirstChild("Humanoid")
    if hum then
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
    end
end

-- ==================== GUI ====================
local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/Vape.txt"))()
local win = lib:Window("AdvanceTech | Strucid", Color3.fromRGB(255, 140, 0), Enum.KeyCode.P)

local tab = win:Tab("Main")

tab:Label("🎯 Head Hitbox")
tab:Toggle("Enable Head Hitbox", false, function(s)
    headEnabled = s
    if s then
        if headConn then headConn:Disconnect() end
        headConn = RunService.Stepped:Connect(updateHeads)
    else
        if headConn then headConn:Disconnect() end
        updateHeads()
    end
end)

tab:Slider("Head Size", 1, 35, 14, function(v)
    headSize = v
    if headEnabled then updateHeads() end
end)

tab:Slider("Head Transparency", 0, 1, 0.6, function(v)
    headTrans = v
    if headEnabled then updateHeads() end
end)

tab:Label("🕹️ Movement")
tab:Toggle("Fly", false, function(s)
    if s then startFly() else endFly() end
end)

tab:Slider("Fly Speed", 10, 200, 60, function(v)
    flySettings.flyspeed = v
end)

tab:Label("⚡ Combat")
tab:Toggle("Rapid Fire", false, function(s)
    rapidFireEnabled = s
end)

tab:Toggle("No Reload", false, function(s)
    noReloadEnabled = s
end)

tab:Toggle("No Fall Damage", true, function(s)
    if s then
        RunService.Heartbeat:Connect(noFallDamage)
    end
end)

-- Gun Mods Loop
RunService.Heartbeat:Connect(function()
    if rapidFireEnabled or noReloadEnabled then
        applyGunMods()
    end
end)

print("✅ AdvanceTech Strucid Loaded | Press P")
