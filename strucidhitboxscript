local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInput = game:GetService("UserInputService")

-- ==================== SETTINGS ====================
local flySpeed = 60
local flying = false

local hitboxEnabled = false
local hitboxSize = 12
local hitboxTransparency = 0.7

local wallhackEnabled = false

-- ==================== FLY ====================
local flyBV, flyBAV, flyChar, flyHum, flyCam

local function startFly()
    if flying or not Player.Character then return end
    flyChar = Player.Character
    flyHum = flyChar:FindFirstChild("Humanoid")
    if not flyHum then return end
    
    flyHum.PlatformStand = true
    flyCam = workspace.CurrentCamera
    
    flyBV = Instance.new("BodyVelocity", flyChar.HumanoidRootPart)
    flyBAV = Instance.new("BodyAngularVelocity", flyChar.HumanoidRootPart)
    
    flyBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    flyBAV.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    flying = true
end

local function endFly()
    if flyHum then flyHum.PlatformStand = false end
    if flyBV then flyBV:Destroy() end
    if flyBAV then flyBAV:Destroy() end
    flying = false
end

-- ==================== HITBOX + WALLHACK ====================
local connections = {}

local function updateHitboxes()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = plr.Character:FindFirstChild("Humanoid")
            
            if root and humanoid then
                -- Regular Hitbox (Whole Body)
                if hitboxEnabled then
                    root.Size = Vector3.new(hitboxSize, hitboxSize*2, hitboxSize)
                    root.Transparency = hitboxTransparency
                    root.CanCollide = false
                    root.Massless = true
                    
                    -- Wallhack (Chams)
                    if wallhackEnabled then
                        for _, part in pairs(plr.Character:GetChildren()) do
                            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                                part.Transparency = 0.3
                                part.Material = Enum.Material.ForceField
                                part.Color = Color3.fromRGB(0, 255, 100)
                            end
                        end
                    end
                else
                    -- Reset
                    root.Size = Vector3.new(2, 2, 1)
                    root.Transparency = 0
                    root.CanCollide = true
                    
                    for _, part in pairs(plr.Character:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.Transparency = 0
                            part.Material = Enum.Material.Plastic
                        end
                    end
                end
            end
        end
    end
end

-- ==================== GUI ====================
local lib = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/UI-Libs/main/Vape.txt"))()
local win = lib:Window("Project Era ESP", Color3.fromRGB(0, 255, 100), Enum.KeyCode.P)

local tab = win:Tab("Main")

tab:Label("🕹️ Movement")
tab:Toggle("Enable Fly", false, function(s)
    if s then
        startFly()
    else
        endFly()
    end
end)

tab:Slider("Fly Speed", 10, 200, 60, function(v)
    flySpeed = v
end)

tab:Label("🎯 Hitbox & Wallhack")
tab:Toggle("Enable Hitbox", false, function(s)
    hitboxEnabled = s
end)

tab:Slider("Hitbox Size", 5, 25, 12, function(v)
    hitboxSize = v
end)

tab:Slider("Hitbox Transparency", 0, 1, 0.7, function(v)
    hitboxTransparency = v
end)

tab:Toggle("Wallhack (Chams)", false, function(s)
    wallhackEnabled = s
end)

-- ==================== MAIN LOOPS ====================
RunService.Heartbeat:Connect(function()
    if flying and flyChar and flyChar.PrimaryPart then
        local camCF = flyCam.CFrame
        local dir = Vector3.new()
        
        if UserInput:IsKeyDown(Enum.KeyCode.W) then dir += camCF.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.S) then dir -= camCF.LookVector end
        if UserInput:IsKeyDown(Enum.KeyCode.A) then dir -= camCF.RightVector end
        if UserInput:IsKeyDown(Enum.KeyCode.D) then dir += camCF.RightVector end
        
        if dir.Magnitude > 0 then
            dir = dir.Unit
        end
        
        flyBV.Velocity = dir * flySpeed
    end
end)

-- Hitbox Update Loop
RunService.Stepped:Connect(function()
    if hitboxEnabled or wallhackEnabled then
        updateHitboxes()
    end
end)

print("✅ Project Era ESP Loaded | Press P to open menu")
